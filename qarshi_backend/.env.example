# Скопируйте в .env и заполните реальными значениями. .env в git НЕ коммитится.

# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,.yourdomain.com

# PostgreSQL
# В Docker DB_HOST/REDIS_URL перекрываются на имена сервисов (db/redis) в docker-compose.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=qarshi
DB_USER=qarshi
DB_PASSWORD=change-me

# Redis (кэш каталога)
REDIS_URL=redis://127.0.0.1:6379/1

# Статичный токен для m2m-эндпоинтов 1С (sync_1c, TokenAuthentication)
API_TOKEN=change-me

# Токен Telegram-бота (fallback; основной токен хранится per-organization в БД)
BOT_TOKEN=change-me
